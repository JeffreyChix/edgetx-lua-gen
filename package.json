{
  "name": "edgetx-lua-gen",
  "version": "1.0.0",
  "description": "GitHub Actions pipeline that parses EdgeTX C++ source files and generates LuaLS definition stubs and API JSON for the EdgeTX Dev Kit VS Code extension.",
  "main": "dist/index.js",
  "author": "Jeffrey Nwankwo",
  "scripts": {
    "start": "npx tsx src/index.ts --version main --withstubs",
    "build": "npx tsc"
  },
  "keywords": [
    "edgetx",
    "github-actions",
    "stubs",
    "lua",
    "api",
    "extractor"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/tinycolor2": "^1.4.6",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "tinycolor2": "^1.6.0"
  }
}
